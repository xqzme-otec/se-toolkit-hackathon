# ─── Telegram ────────────────────────────────────────────────────────
BOT_TOKEN=

# ─── OpenRouter (если LLM_PROVIDER=openrouter) ──────────────────────
OPENROUTER_API_KEY=

# ─── LLM ────────────────────────────────────────────────────────────
# openrouter — через OpenRouter API
# ollama    — локально, без лимитов
LLM_PROVIDER=ollama

# Для ollama:
LLM_MODEL=qwen3:4b
LLM_BASE_URL=http://localhost:11434

# Для openrouter:
# LLM_MODEL=qwen/qwen3-coder:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# ─── База данных ────────────────────────────────────────────────────
USE_SQLITE=1
POSTGRES_DB=debtors
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
